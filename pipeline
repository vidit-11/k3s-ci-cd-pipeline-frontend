name: Production CI/CD

on:
  push:
    branches:
      - main

jobs:
  # --- JOB 1: Build Image ---
  build-and-push:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout Code
        uses: actions/checkout@v4

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      - name: Login to Docker Hub
        uses: docker/login-action@v3
        with:
          username: ${{ secrets.DOCKER_HUB_USERNAME }}
          password: ${{ secrets.DOCKER_HUB_TOKEN }}

      - name: Build and Push
        uses: docker/build-push-action@v5
        with:
          context: .
          push: true
          tags: your-username/your-app:latest
          cache-from: type=gha
          cache-to: type=gha,mode=max

  # --- JOB 2: Deploy to K3s ---
  deploy:
    needs: build-and-push 
    runs-on: ubuntu-latest
    steps:
      - name: Checkout Code
        uses: actions/checkout@v4

      - name: Set up Kubeconfig
        run: |
          mkdir -p ~/.kube
          # Replace this secret in GitHub Settings > Secrets
          echo "${{ secrets.K3S_KUBECONFIG }}" > ~/.kube/config
          chmod 600 ~/.kube/config

      - name: Update K3s Deployment
        run: |
          # This triggers the rolling update in K3s
          # Change 'your-app-name' and 'your-namespace' to match your K8s manifest
          kubectl rollout restart deployment/your-app-name -n your-namespace
